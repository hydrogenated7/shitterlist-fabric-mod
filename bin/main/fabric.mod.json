{
  "schemaVersion": 1,
  "id": "shitterlist",
  "version": "${version}",
  "name": "ShitterList",
  "description": "Automatically removes specified players from your party when they join via party finder on Hypixel Skyblock",
  "authors": [
    "YourName"
  ],
  "contact": {
    "homepage": "https://github.com/yourname/shitterlist",
    "sources": "https://github.com/yourname/shitterlist"
  },
  "license": "MIT",
  "icon": "assets/shitterlist/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.example.shitterlist.ShitterListMod"
    ],
    "client": [
      "com.example.shitterlist.ShitterListClient"
    ]
  },
  "mixins": [
    "shitterlist.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "fabric-api": "*",
    "minecraft": "~1.21",
    "java": ">=21"
  },
  "suggests": {
    "modmenu": ">=11.0.0-beta.1"
  }
